{
  "routes": [
    { "src": "/(.*)", "headers": { "X-Content-Type-Options": "nosniff", "Referrer-Policy": "strict-origin-when-cross-origin" }, "continue": true },
    { "src": "/agent/([^/]+)/admin$", "dest": "/admin.html?agent=$1" },
    { "src": "/agent/([^/]+)/([^/]+)$", "dest": "/agent-site.html?slug=$1&page=$2" },
    { "src": "/agent/([^/]+)/?$", "dest": "/agent-site.html?slug=$1" },
    { "handle": "filesystem" },
    { "src": "/admin$", "dest": "/admin.html" },
    { "src": "/login$", "dest": "/login.html" },
    { "src": "/merchant$", "dest": "/merchant.html" },
    { "src": "/footer-page$", "dest": "/footer-page.html" },
    { "src": "/agent-site$", "dest": "/agent-site.html" },
    { "src": "/contest$", "dest": "/contest.html" }
  ],
  "functions": {
    "api/ai.js": { "maxDuration": 30 }
  }
}
